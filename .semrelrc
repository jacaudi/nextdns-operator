{
  "plugins": {
    "commit-analyzer": {
      "name": "default@^1.0.0"
    },
    "changelog-generator": {
      "name": "default@^1.0.0",
      "options": {
        "emojis": "false",
        "format_commit_template": "* {{with .Scope -}} **{{.}}:** {{end}} {{- .Message}} ([{{trimSHA .SHA}}](https://github.com/jacaudi/nextdns-operator/commit/{{.SHA}}))"
      }
    },
    "provider": {
      "name": "github"
    }
  },
  "hooks": {
    "post-changelog": [
      "if [ -f \"chart/Chart.yaml\" ]; then\n  sed -i \"s/^version:.*/version: ${RELEASE_VERSION}/\" chart/Chart.yaml\n  sed -i \"s/^appVersion:.*/appVersion: \\\"${RELEASE_VERSION}\\\"/\" chart/Chart.yaml\n  git add chart/Chart.yaml\nfi"
    ]
  }
}
