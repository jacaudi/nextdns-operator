{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>jacaudi/renovate-config:base",
    "github>jacaudi/renovate-config:go",
    "github>jacaudi/renovate-config:kubernetes"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^Makefile$/"
      ],
      "matchStrings": [
        "CONTROLLER_TOOLS_VERSION \\?= (?<currentValue>v[0-9.]+)"
      ],
      "depNameTemplate": "sigs.k8s.io/controller-tools",
      "datasourceTemplate": "go"
    }
  ],
  "packageRules": [
    {
      "description": "Regenerate CRDs and sync to Helm chart after controller-tools updates",
      "matchDepNames": [
        "sigs.k8s.io/controller-tools"
      ],
      "postUpgradeTasks": {
        "commands": [
          "make manifests",
          "make sync-helm-crds"
        ],
        "fileFilters": [
          "config/crd/bases/*.yaml",
          "chart/crds/*.yaml"
        ],
        "executionMode": "branch"
      }
    }
  ]
}
